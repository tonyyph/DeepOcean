{
    "expo": {
        "name": "Deep Ocean",
        "slug": "deep-ocean",
        "version": "1.0.0",
        "orientation": "portrait",
        "scheme": "deepocean",
        "userInterfaceStyle": "dark",
        "newArchEnabled": true,
        "icon": "./assets/deepocean.png",
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.tony.deepocean",
            "infoPlist": {
                "UIBackgroundModes": [
                    "audio"
                ]
            }
        },
        "android": {
            "package": "com.tony.deepocean",
            "adaptiveIcon": {
                "foregroundImage": "./assets/deepocean.png",
                "backgroundColor": "#020617"
            }
        },
        "web": {
            "bundler": "metro"
        },
        "plugins": [
            "expo-router",
            "expo-font",
            [
                "expo-av",
                {
                    "microphonePermission": false
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true
        }
    }
}