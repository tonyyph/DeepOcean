{
  "expo": {
    "name": "Deep Ocean",
    "slug": "deep-ocean",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "deepocean",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/deepocean.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cuongphan2.OtherSide",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.cuongphan2.OtherSide",
      "adaptiveIcon": {
        "foregroundImage": "./assets/deepocean.png",
        "backgroundColor": "#020617"
      },
      "permissions": [
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#020617",
          "image": "./assets/logo.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "9f7f0961-08c2-4d84-9d99-bd1a55a06e42"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9f7f0961-08c2-4d84-9d99-bd1a55a06e42"
    },
    "owner": "cuongphan2"
  }
}