{
  "expo": {
    "name": "Deep Ocean",
    "slug": "deep-ocean",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "deepocean",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/images/deepocean-fixed.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cuongphan2.OtherSide",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.cuongphan2.OtherSide",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/deepocean-fixed.png",
        "backgroundColor": "#020617"
      },
      "permissions": [
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-build-properties",
        {
          "ios": {
            "buildReactNativeFromSource": true
          }
        }
      ],
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": true,
          "enableBackgroundRecording": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#020617",
          "image": "./assets/images/logo.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#22E4FF",
          "sounds": [
            "./assets/audio/luffy.wav"
          ]
        }
      ],
      [
        "./plugins/with-focus-widget",
        {
          "appGroup": "group.com.cuongphan2.OtherSide"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "9f7f0961-08c2-4d84-9d99-bd1a55a06e42"
      },
      "revenuecat": {
        "iosKey": "",
        "androidKey": "",
        "premiumEntitlement": "premium",
        "themeEntitlementPrefix": "theme_",
        "lifetimePackageId": "lifetime"
      },
      "diveNotifications": {
        "completionSound": "luffy.wav"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9f7f0961-08c2-4d84-9d99-bd1a55a06e42"
    },
    "owner": "cuongphan2"
  }
}
