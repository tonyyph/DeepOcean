{
  "name": "deep-ocean",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint && npx tsc --noEmit",
    "all": "watchman watch-del-all && rm -rf yarn.lock && rm -rf node_modules/",
    "setup": "npx expo install",
    "prebuild": "npx expo prebuild --clean --no-install",
    "generate:index": "ruby ./scripts/generate-index.rb",
    "eas:login": "eas login",
    "eas:logout": "eas logout",
    "build:ios:internal": "eas build --platform ios --profile internal",
    "build:android:internal": "eas build --platform android --profile internal",
    "build:ios:dev": "eas build --platform ios --profile develop --verbose-logs --wait  --non-interactive",
    "build:android:dev": "eas build --platform android --profile develop --verbose-logs --wait  --non-interactive",
    "build:ios:test": "eas build --platform ios --profile test --verbose-logs --wait  --non-interactive",
    "build:android:test": "eas build --platform android --profile test --verbose-logs --wait  --non-interactive",
    "build:ios:prod": "eas build --platform ios --profile production --verbose-logs --wait  --non-interactive",
    "build:android:prod": "eas build --platform android --profile production --verbose-logs --wait  --non-interactive",
    "submit:android:prod": "eas submit --platform android --profile production --latest --verbose --verbose-fastlane --wait",
    "submit:android:dev": "eas submit --platform android --profile develop --latest --verbose --verbose-fastlane --wait",
    "submit:android:test": "eas submit --platform android --profile test --latest --verbose --verbose-fastlane --wait",
    "submit:ios:dev": "eas submit --platform ios --profile develop --latest --verbose --verbose-fastlane --wait",
    "submit:ios:test": "eas submit --platform ios --profile test --latest --verbose --verbose-fastlane --wait",
    "submit:ios:prod": "eas submit --platform ios --profile production --latest --verbose --verbose-fastlane --wait",
    "start": "expo start -c",
    "test": "jest"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/sora": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-community/slider": "4.5.5",
    "@shopify/flash-list": "1.7.3",
    "@shopify/react-native-skia": "1.5.0",
    "@tanstack/react-query": "^5.59.0",
    "expo": "~52.0.0",
    "expo-application": "~6.0.2",
    "expo-av": "~15.0.1",
    "expo-blur": "~14.0.1",
    "expo-constants": "~17.0.3",
    "expo-dev-client": "~5.0.20",
    "expo-font": "~13.0.1",
    "expo-haptics": "~14.0.0",
    "expo-linear-gradient": "~14.0.1",
    "expo-notifications": "~0.29.14",
    "expo-router": "~4.0.9",
    "expo-splash-screen": "~0.29.13",
    "expo-status-bar": "~2.0.0",
    "expo-system-ui": "~4.0.5",
    "expo-updates": "~0.27.5",
    "moti": "^0.30.0",
    "nativewind": "^4.1.20",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-mmkv": "3.1.0",
    "react-native-purchases": "^10.2.0",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "tailwindcss": "^3.4.14",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.3.12",
    "eas-cli": "^20.0.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "husky": "9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~52.0.6",
    "typescript": "~5.3.3"
  },
  "precommit": "lint"
}