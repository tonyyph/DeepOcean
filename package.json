{
  "name": "deep-ocean",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint && npx tsc --noEmit",
    "all": "watchman watch-del-all && rm -rf yarn.lock && rm -rf node_modules/",
    "setup": "npx expo install",
    "prebuild": "npx expo prebuild --no-install",
    "clear-derived": "rm -rf ~/Library/Developer/Xcode/DerivedData/DeepOcean-*",
    "widget": "ruby ./scripts/patch-ios-widget-target.rb && node ./scripts/check-widget-native.js",
    "check:widget-native": "node ./scripts/check-widget-native.js",
    "check:audio-assets": "node ./scripts/check-audio-assets.js",
    "patch:ios-widget-target": "ruby ./scripts/patch-ios-widget-target.rb",
    "generate:index": "ruby ./scripts/generate-index.rb",
    "postinstall": "patch-package",
    "eas:login": "eas login",
    "eas:logout": "eas logout",
    "build:ios:internal": "eas build --platform ios --profile internal",
    "build:android:internal": "eas build --platform android --profile internal",
    "build:ios:dev": "eas build --platform ios --profile develop --verbose-logs --wait  --non-interactive",
    "build:android:dev": "eas build --platform android --profile develop --verbose-logs --wait  --non-interactive",
    "build:ios:test": "eas build --platform ios --profile test --verbose-logs --wait  --non-interactive",
    "build:android:test": "eas build --platform android --profile test --verbose-logs --wait  --non-interactive",
    "build:ios:prod": "eas build --platform ios --profile production --verbose-logs --wait  --non-interactive",
    "build:android:prod": "eas build --platform android --profile production --verbose-logs --wait  --non-interactive",
    "submit:android:prod": "eas submit --platform android --profile production --latest --verbose --verbose-fastlane --wait",
    "submit:android:dev": "eas submit --platform android --profile develop --latest --verbose --verbose-fastlane --wait",
    "submit:android:test": "eas submit --platform android --profile test --latest --verbose --verbose-fastlane --wait",
    "submit:ios:dev": "eas submit --platform ios --profile develop --latest --verbose --verbose-fastlane --wait",
    "submit:ios:test": "eas submit --platform ios --profile test --latest --verbose --verbose-fastlane --wait",
    "submit:ios:prod": "eas submit --platform ios --profile production --latest --verbose --verbose-fastlane --wait",
    "start": "expo start -c",
    "test": "jest"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/sora": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/dom-webview": "~56.0.5",
    "@expo/log-box": "~56.0.13",
    "@expo/metro-runtime": "~56.0.15",
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-community/slider": "5.2.0",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.6.2",
    "@tanstack/react-query": "5.101.0",
    "expo": "~56.0.12",
    "expo-application": "~56.0.3",
    "expo-asset": "~56.0.17",
    "expo-audio": "~56.0.12",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.19",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.19",
    "moti": "^0.30.0",
    "nativewind": "4.2.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-mmkv": "3.1.0",
    "react-native-purchases": "10.2.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.8.3",
    "tailwindcss": "^3.4.14",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native/jest-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@testing-library/dom": "^10.4.1",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~56.0.4",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.5",
    "patch-package": "^8.0.1",
    "typescript": "~6.0.3"
  }
}