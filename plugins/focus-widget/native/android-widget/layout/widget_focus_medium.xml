<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_ocean_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@null"
                android:src="@drawable/deep_ocean_logo" />

            <TextView
                android:id="@+id/widget_premium_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:letterSpacing="0.1"
                android:text="ABYSS+"
                android:textColor="#F9C264"
                android:textSize="8sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <Space android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.1"
            android:text="TODAY"
            android:textColor="#ABC9DA"
            android:textSize="8sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_today_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="0 min"
            android:textColor="#EFF8FF"
            android:textSize="25sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/widget_today_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="128dp"
            android:layout_height="5dp"
            android:layout_marginTop="7dp"
            android:max="100"
            android:progress="0"
            android:progressBackgroundTint="#263D5061"
            android:progressTint="#40E8F5" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="24dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_zone_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Sunlight Zone"
            android:textColor="#EFF8FF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_context_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="0m · 0 day streak"
            android:textColor="#ABC9DA"
            android:textSize="10sp" />

        <Space android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="1" />

        <TextView
            android:id="@+id/widget_primary_action"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:background="@drawable/widget_primary_cta"
            android:contentDescription="Start an ocean focus dive"
            android:gravity="center"
            android:text="↓  Start Dive"
            android:textColor="#04101C"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
