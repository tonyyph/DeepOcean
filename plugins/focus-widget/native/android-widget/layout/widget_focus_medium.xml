<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_ocean_background"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_primary_action"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.75"
                android:background="@drawable/widget_primary_cta"
                android:contentDescription="Start focus session"
                android:gravity="center"
                android:minHeight="72dp"
                android:padding="12dp"
                android:text="Start Focus"
                android:textColor="#02111D"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_secondary_ai"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="@drawable/widget_secondary_action"
                    android:contentDescription="Open AI companion"
                    android:gravity="center"
                    android:minHeight="48dp"
                    android:text="AI"
                    android:textColor="#EAF6FF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_secondary_progress"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/widget_secondary_action"
                    android:contentDescription="View daily progress"
                    android:gravity="center"
                    android:minHeight="48dp"
                    android:text="Stats"
                    android:textColor="#EAF6FF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/widget_glass_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <TextView
                android:id="@+id/widget_context_primary"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:maxLines="1"
                android:text="Ready for a 25m dive"
                android:textColor="#EAF6FF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_premium_badge"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/widget_premium_pill"
                android:gravity="center"
                android:minWidth="42dp"
                android:paddingHorizontal="8dp"
                android:text="PRO"
                android:textColor="#FFD27A"
                android:textSize="9sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_context_secondary"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:background="@drawable/widget_progress_chip"
                android:gravity="center"
                android:minWidth="44dp"
                android:paddingHorizontal="8dp"
                android:text="Today"
                android:textColor="#BFF7FF"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
