<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_ocean_background"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_premium_badge"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:layout_gravity="end"
            android:background="@drawable/widget_premium_pill"
            android:gravity="center"
            android:minWidth="42dp"
            android:paddingHorizontal="9dp"
            android:text="PRO"
            android:textColor="#FFD27A"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_primary_action"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="5dp"
            android:layout_weight="1"
            android:background="@drawable/widget_primary_cta"
            android:contentDescription="Start focus session"
            android:gravity="center"
            android:minHeight="56dp"
            android:paddingHorizontal="8dp"
            android:text="Start Focus"
            android:textColor="#02111D"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_context_primary"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:maxLines="1"
                android:text="Next: 25m"
                android:textColor="#EAF6FF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_context_secondary"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@drawable/widget_progress_chip"
                android:gravity="center"
                android:minWidth="42dp"
                android:paddingHorizontal="8dp"
                android:text="Today"
                android:textColor="#BFF7FF"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
